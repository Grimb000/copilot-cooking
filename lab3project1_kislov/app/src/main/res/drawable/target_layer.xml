<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/target_outer" />
        </shape>
    </item>
    <item android:width="64dp" android:height="64dp" android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/target_mid" />
        </shape>
    </item>
    <item android:width="32dp" android:height="32dp" android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/target_inner" />
        </shape>
    </item>
</layer-list>
